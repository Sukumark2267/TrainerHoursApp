@model TrainerHoursApp.Models.TrainerHour

@{
    ViewData["Title"] = "Edit Trainer Hours";
}

<div class="container d-flex justify-content-center mt-4">
    <div class="glass-card glass-card-small p-4" style="max-width: 480px; width: 100%;">

        <h3 class="page-title mb-3" style="font-size: 1.7rem;">Edit Trainer Hours</h3>
        <hr class="mb-4" />

        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label small fw-semibold"></label>
                <input asp-for="Name" class="form-control form-control-sm" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Branch" class="form-label small fw-semibold"></label>
                <input asp-for="Branch" class="form-control form-control-sm" />
                <span asp-validation-for="Branch" class="text-danger small"></span>
            </div>
            <div class="mb-2">
                <label class="form-label small fw-semibold">Batch</label>
                <input class="form-control form-control-sm" name="Batch" id="editBatch" />
            </div>
            <div class="mb-3">
                <label asp-for="Date" class="form-label small fw-semibold"></label>
                <input asp-for="Date" type="date" class="form-control form-control-sm" />
            </div>

            <div class="mb-3">
                <label asp-for="Hours" class="form-label small fw-semibold"></label>
                <input asp-for="Hours" class="form-control form-control-sm" />
            </div>

            <div class="mb-3">
                <label asp-for="TotalHours" class="form-label small fw-semibold"></label>
                <input asp-for="TotalHours" class="form-control form-control-sm" />
            </div>
            <div class="mb-3">
                <label class="form-label small fw-semibold">Notes</label>
                <textarea class="form-control form-control-sm" rows="2" name="Notes" id="editNotes"></textarea>
            </div>
            <div class="d-flex justify-content-between mt-4">
                <button type="submit" class="btn-brand px-4 py-2">Update</button>
                <a asp-action="Index" class="btn-delete px-4 py-2">Cancel</a>
            </div>

        </form>

    </div>
</div>