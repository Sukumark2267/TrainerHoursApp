@model IEnumerable<TrainerHoursApp.Models.TrainerAllocation>

@{
    ViewData["Title"] = "Trainer Dashboard";

    // Group by Trainer + TrainingTitle so same trainer with different topics gets separate cards
    var groupedTrainers = Model
        .GroupBy(t => new { t.TrainerName, t.TrainingTitle })
        .OrderBy(g => g.Key.TrainerName);
}

<div class="container py-4">

    <!-- Page header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title mb-1">Trainer Dashboard</h2>
            <p class="subtitle mb-0">
                View all trainers, their trainings and allocations in one place.
            </p>
        </div>

        <div>
            <a asp-action="AddTrainer" class="btn btn-primary btn-lg">
                + Add Trainer
            </a>
        </div>
    </div>

    <!-- Filter pills + search -->
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">

        <ul class="nav nav-pills trainer-tabs">
            <li class="nav-item">
                <button class="nav-link active" type="button">All</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" type="button">Ongoing</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" type="button">Completed</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" type="button">Upcoming</button>
            </li>
        </ul>

        <div class="input-group" style="max-width: 260px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input id="trainerSearch" type="text" class="form-control" placeholder="Search trainer or title" />
        </div>
    </div>

    @if (!groupedTrainers.Any())
    {
        <div class="glass-card p-4 text-center text-muted">
            No trainer allocations yet. Click <strong>Add Trainer</strong> to create the first one.
        </div>
    }
    else
    {
        <div id="trainerCards" class="d-flex flex-column gap-3">

            @foreach (var group in groupedTrainers)
            {
                var first = group.OrderByDescending(g => g.TrainerName).First();
                var branches = string.Join(", ", group.Select(g => g.Branch).Distinct());
                var sections = string.Join(", ", group.Select(g => g.Section).Where(s => !string.IsNullOrWhiteSpace(s)).Distinct());
                var year = string.Join(", ", group.Select(g => g.Year).Distinct().OrderBy(y => y));
                //var totalPlanned = group.Sum(g => g.TotalHours);
              //  var allocationsCount = group.Count();

                <div class="glass-card trainer-card p-3" data-search="@($"{group.Key.TrainerName} {group.Key.TrainingTitle} {branches}")">
                    <div class="row g-3 align-items-center">

                        <!-- Left column: name + title + meta -->
                        <div class="col-md-5">
                            <div class="d-flex align-items-start gap-3">
                                <!-- Avatar circle (initials) -->
                                <div class="avatar-circle">
                                    @(!string.IsNullOrWhiteSpace(group.Key.TrainerName)
                                        ? group.Key.TrainerName.Trim()[0].ToString().ToUpper()
                                        : "T")
                                </div>

                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <h5 class="mb-0 fw-semibold">@group.Key.TrainerName</h5>
                                        @if (!string.IsNullOrWhiteSpace(year))
                                        {
                                            <span class="badge rounded-pill bg-light text-muted">
                                                @(year + (year.Contains(",") ? " Years" : " Year"))
                                            </span>
                                        }
                                    </div>

                                    <div class="text-muted small mb-1">
                                        @if (!string.IsNullOrWhiteSpace(group.Key.TrainingTitle))
                                        {
                                            <span class="fw-semibold">@group.Key.TrainingTitle</span>
                                        }
                                        else
                                        {
                                            <span class="fst-italic">No training title set</span>
                                        }
                                    </div>

                                    <div class="text-muted small">
                                        <i class="bi bi-diagram-3 me-1"></i>
                                        Branches:
                                        <span class="fw-semibold">@branches</span>
                                        @if (!string.IsNullOrWhiteSpace(sections))
                                        {
                                            <span class="text-muted"> | Sections: </span>
                                            <span class="fw-semibold">@sections</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                       

                        <!-- Right column: buttons -->
                        <div class="col-md-3 text-md-end">
                            <div class="d-flex justify-content-md-end gap-2 flex-wrap">
                                <!-- Edit Hours: for now, go to Edit of the latest record -->
                                <a asp-action="Edit" asp-route-id="@first.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    Edit Hours
                                </a>

                                <!-- View Details: trainer summary with calendar etc. -->
                                <a asp-action="TrainerDetails" asp-route-name="@group.Key.TrainerName"
                                   class="btn btn-outline-secondary btn-sm">
                                    View Details
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-3 small text-muted">
        <span class="fw-semibold">Note:</span>
        Each card groups all branches / sections for the same trainer and training title.
        Planned hours = sum of all allocated hours for that trainer.
    </div>
</div>

@section Scripts {
    <script>
        // Simple client-side search on trainer name / title / branch
        document.addEventListener('DOMContentLoaded', function () {
            var searchInput = document.getElementById('trainerSearch');
            var cardsContainer = document.getElementById('trainerCards');

            if (!searchInput || !cardsContainer) return;

            searchInput.addEventListener('input', function () {
                var term = this.value.toLowerCase();

                cardsContainer.querySelectorAll('.trainer-card').forEach(function (card) {
                    var text = card.getAttribute('data-search') || '';
                    text = text.toLowerCase();

                    if (text.indexOf(term) !== -1) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });
    </script>

    <style>
        /* Extra styling to match the soft card look */

        .trainer-tabs .nav-link {
            border-radius: 999px;
            padding: 0.35rem 0.9rem;
            font-size: 0.9rem;
        }

        .trainer-tabs .nav-link.active {
            background-color: #0d6efd;
            color: #fff;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            border-radius: 18px;
            box-shadow: 0 15px 35px rgba(15, 23, 42, 0.08);
            border: 1px solid rgba(148, 163, 184, 0.25);
        }

        .trainer-card .avatar-circle {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0d6efd, #4f46e5);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 1.1rem;
            box-shadow: 0 6px 16px rgba(37, 99, 235, 0.35);
        }

        .summary-pill {
            background-color: rgba(15, 23, 42, 0.02);
            border-radius: 12px;
            padding: 0.5rem 0.75rem;
            border: 1px dashed rgba(148, 163, 184, 0.6);
        }
    </style>
}